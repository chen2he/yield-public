{
	"name": "yield-public",
	"version": "0.1.0",
	"private": true,
	"license": "SEE LICENSE IN LICENSE",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:migrate:remote": "wrangler d1 migrations apply DB --remote",
		"sync:self-reference": "node scripts/sync-self-reference.mjs",
		"deploy": "pnpm run sync:self-reference && pnpm run db:migrate:remote && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.19.9",
		"@peculiar/x509": "^1.14.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"jose": "^6.2.3",
		"lucide-react": "^1.22.0",
		"next": "16.2.6",
		"next-intl": "^4.13.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.6.0",
		"react": "^19.1.7",
		"react-dom": "^19.1.7",
		"recharts": "3.8.0",
		"shadcn": "^4.12.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"vaul": "^1.1.2"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20.19.43",
		"@types/react": "^19.1.7",
		"@types/react-dom": "^19.1.7",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.105.0"
	}
}